{
  "name": "pump-clone-backend",
  "version": "0.1.0",
  "description": "Backend API for the pump.fun clone on Solana using Meteora Dynamic Bonding Curve",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "solana",
    "pump.fun",
    "meteora",
    "bonding-curve",
    "dbc"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@meteora-ag/dynamic-bonding-curve-sdk": "^1.5.7",
    "@prisma/client": "^6.19.3",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "bullmq": "^5.76.9",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "leo-profanity": "^1.9.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react-helmet-async": "^3.0.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}

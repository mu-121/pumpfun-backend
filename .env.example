# Application
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pump_clone?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Solana / Helius
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=your-helius-api-key
SOLANA_NETWORK=devnet

# Meteora Dynamic Bonding Curve
# DBC_CONFIG_KEY is the on-chain config account for your launch config (filled in Phase 2 once created)
DBC_CONFIG_KEY=
DBC_PROGRAM_ID=dbcij3LWUppWqq96dh6gJWwBifmcGfLSB5D4DuSMaqN

# Platform
PLATFORM_WALLET_PUBKEY=your-platform-wallet-pubkey
# Path to the Solana keypair JSON for the platform/partner wallet. Used by
# scripts/create-config-key.ts and any signer-side workers. Should be a 64-byte
# JSON array as produced by `solana-keygen new -o keypair.json`. Keep this file
# OUT of git.
PLATFORM_WALLET_KEYPAIR_PATH=./keypair.json

# Cloudflare R2 (token image storage)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=pump-clone-assets
R2_PUBLIC_URL=https://assets.example.com

# CORS — comma-separated list of allowed origins, or "*" for any
CORS_ORIGIN=http://localhost:5173

# Webhook auth — used to validate Helius webhooks. Generate a 32+ char random secret.
WEBHOOK_AUTH_SECRET=replace-with-a-long-random-secret-min-16-chars
